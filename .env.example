# LLM provider
OPENROUTER_API_KEY=your-key-here

# ---------------------------------------------------------------------------
# MCP servers (opt-in; unset or "0" disables each server)
# ---------------------------------------------------------------------------
#
# Keep secrets and machine-specific paths here, not in tracked config files.

# Web Search MCP (mrkrsl/web-search-mcp)
AGENT_ENABLE_MCP_WEB_SEARCH=0
# AGENT_MCP_WEB_SEARCH_COMMAND=npx
# AGENT_MCP_WEB_SEARCH_ARGS=-y web-search-mcp@latest

# GitHub MCP (github/github-mcp-server)
AGENT_ENABLE_MCP_GITHUB=0
# AGENT_MCP_GITHUB_COMMAND=/absolute/path/to/github-mcp-server
# AGENT_MCP_GITHUB_ARGS=stdio
# Comma-separated GitHub MCP toolsets (default in code: repos,pull_requests,issues,actions,context)
# AGENT_MCP_GITHUB_TOOLSETS=repos,pull_requests,issues,actions,context
# Required for any real GitHub MCP call:
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxx
